.product-manage-page { background: #f5f5f5; min-height: 100vh; }
.page-header { display: flex; justify-content: space-between; align-items: center; padding: 24rpx; background: #fff; }
.page-title { font-size: 34rpx; font-weight: bold; }
.btn-sm { padding: 10rpx 24rpx; font-size: 24rpx; }
.product-card { }
.product-img { width: 180rpx; height: 180rpx; border-radius: 12rpx; flex-shrink: 0; }
.product-info { flex: 1; margin-left: 16rpx; display: flex; flex-direction: column; justify-content: space-between; }
.product-name { font-size: 30rpx; font-weight: bold; }
.product-desc { font-size: 24rpx; color: #666; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
.product-stock { font-size: 22rpx; color: #999; }
.product-tags { margin-top: 8rpx; }
.product-actions { display: flex; justify-content: flex-end; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; }
.action-btn { padding: 8rpx 24rpx; border: 1rpx solid #ddd; border-radius: 24rpx; font-size: 24rpx; margin-left: 12rpx; }
.action-btn.danger { color: #FF3B30; border-color: #FF3B30; }
