<!--pages/my-reviews/my-reviews.wxml-->
<view class="review-page">
  <view class="page-header">
    <text class="page-title">我的评价</text>
  </view>
  <view class="review-list" wx:if="{{reviews.length}}">
    <view class="review-card card" wx:for="{{reviews}}" wx:key="_id">
      <view class="review-store" bindtap="goStore" data-type="{{item.type}}" data-id="{{item.storeId}}">
        <text class="store-name">{{item.storeName}}</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="flex" style="margin:12rpx 0">
        <text class="review-stars">{{'⭐'.repeat(item.rating)}}</text>
        <text class="review-time">{{item.createdAt}}</text>
      </view>
      <text class="review-content">{{item.content}}</text>
      <view class="review-images" wx:if="{{item.images && item.images.length}}">
        <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="aspectFill" class="review-img"/>
      </view>
      <view class="review-reply" wx:if="{{item.reply}}">
        <text class="reply-label">商家回复：</text>
        <text class="reply-content">{{item.reply}}</text>
      </view>
    </view>
  </view>
  <view class="empty" wx:if="{{!loading && !reviews.length}}">
    <text class="empty-icon">⭐</text>
    <text class="empty-text">还没有评价</text>
    <text class="empty-hint">完成订单后可以评价哦</text>
  </view>
  <view class="loading-more" wx:if="{{loading}}">加载中...</view>
</view>
