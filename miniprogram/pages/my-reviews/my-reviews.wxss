.review-page { background: #f5f5f5; min-height: 100vh; }
.page-header { display: flex; justify-content: space-between; align-items: center; padding: 24rpx; background: #fff; }
.page-title { font-size: 34rpx; font-weight: bold; }
.review-card { }
.review-store { display: flex; justify-content: space-between; align-items: center; padding-bottom: 12rpx; border-bottom: 1rpx solid #f5f5f5; }
.store-name { font-size: 28rpx; font-weight: bold; }
.menu-arrow { color: #ccc; font-size: 32rpx; }
.review-stars { font-size: 22rpx; }
.review-time { font-size: 22rpx; color: #ccc; margin-left: auto; }
.review-content { font-size: 26rpx; color: #333; line-height: 1.6; display: block; margin: 8rpx 0; }
.review-images { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 8rpx; }
.review-img { width: 120rpx; height: 120rpx; border-radius: 8rpx; }
.review-reply { background: #f8f8f8; border-radius: 12rpx; padding: 16rpx; margin-top: 12rpx; }
.reply-label { font-size: 24rpx; color: #FF6B35; }
.reply-content { font-size: 24rpx; color: #666; }
.empty { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 30rpx; color: #666; margin-top: 16rpx; display: block; }
.empty-hint { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.loading-more { text-align: center; padding: 30rpx; color: #999; font-size: 24rpx; }
