.home-page {
  background: #f5f5f5;
  min-height: 100vh;
}

.home-header {
  background: #FF6B35;
  padding: 20rpx 24rpx 30rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.location-bar {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  color: #fff;
  font-size: 26rpx;
}
.location-icon { margin-right: 8rpx; }
.location-text { max-width: 300rpx; }
.location-arrow { margin-left: 8rpx; font-size: 20rpx; }

.search-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 36rpx;
  padding: 0 20rpx;
}
.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
}
.search-btn {
  background: #FF6B35;
  color: #fff;
  border-radius: 28rpx;
  padding: 10rpx 28rpx;
  font-size: 26rpx;
}

.banner-swiper {
  height: 320rpx;
  margin: -10rpx 20rpx 0;
  border-radius: 16rpx;
  overflow: hidden;
}
.banner-img {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  background: #fff;
  margin: 20rpx 20rpx 0;
  border-radius: 16rpx;
}
.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}
.category-icon {
  width: 88rpx;
  height: 88rpx;
  margin-bottom: 12rpx;
}
.category-name {
  font-size: 24rpx;
  color: #333;
}

.section {
  margin-top: 20rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx 0;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
}
.section-more {
  font-size: 24rpx;
  color: #999;
}

.scroll-h {
  white-space: nowrap;
  padding: 16rpx 20rpx;
}
.hotel-card {
  display: inline-block;
  width: 340rpx;
  margin-right: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.hotel-img {
  width: 340rpx;
  height: 220rpx;
}
.hotel-info {
  padding: 16rpx;
}
.hotel-name {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
}
.hotel-tags {
  margin: 8rpx 0;
}
.hotel-score {
  font-size: 22rpx;
  color: #FF9500;
}

.food-list { padding: 0 20rpx; }
.food-card {
  display: flex;
  padding: 0 !important;
  overflow: hidden;
}
.food-img {
  width: 200rpx;
  height: 180rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
}
.food-info {
  flex: 1;
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.food-name {
  font-size: 30rpx;
  font-weight: bold;
}
.food-desc {
  font-size: 24rpx;
  color: #999;
}
.food-distance {
  font-size: 22rpx;
  color: #999;
}

.product-card {
  display: inline-block;
  width: 240rpx;
  margin-right: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  padding-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.product-img {
  width: 240rpx;
  height: 240rpx;
}
.product-name {
  font-size: 26rpx;
  padding: 12rpx 12rpx 0;
  display: block;
}
.product-sales {
  font-size: 22rpx;
  color: #999;
  padding-right: 12rpx;
}
