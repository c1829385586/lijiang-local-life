<!--pages/order-confirm/order-confirm.wxml-->
<view class="order-confirm">
  <!-- 收货地址（特产/零食） -->
  <view class="card address-card" wx:if="{{orderData.type === 'product'}}" bindtap="chooseAddress">
    <view wx:if="{{address}}">
      <view class="flex">
        <text class="addr-name">{{address.userName}}</text>
        <text class="addr-phone">{{address.telNumber}}</text>
      </view>
      <text class="addr-detail">{{address.provinceName}}{{address.cityName}}{{address.countyName}}{{address.detailInfo}}</text>
    </view>
    <view wx:else class="flex-center" style="padding:30rpx;">
      <text>+ 请选择收货地址</text>
    </view>
  </view>

  <!-- 入住信息（酒店） -->
  <view class="card" wx:if="{{orderData.type === 'hotel'}}">
    <text class="card-title">入住信息</text>
    <view class="info-row">
      <text class="info-label">入住日期</text>
      <text class="info-value">{{orderData.checkInDate}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">退房日期</text>
      <text class="info-value">{{orderData.checkOutDate}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">入住天数</text>
      <text class="info-value">{{orderData.nights}}晚</text>
    </view>
    <view class="info-row">
      <text class="info-label">入住人</text>
      <input class="info-input" placeholder="请输入入住人姓名" bindinput="onGuestInput" value="{{guestName}}"/>
    </view>
    <view class="info-row">
      <text class="info-label">手机号</text>
      <input class="info-input" placeholder="请输入手机号" type="number" bindinput="onPhoneInput" value="{{guestPhone}}"/>
    </view>
  </view>

  <!-- 联系人信息（美食/游玩） -->
  <view class="card" wx:if="{{orderData.type === 'food' || orderData.type === 'travel'}}">
    <text class="card-title">联系人信息</text>
    <view class="info-row">
      <text class="info-label">联系人</text>
      <input class="info-input" placeholder="请输入联系人姓名" bindinput="onGuestInput" value="{{guestName}}"/>
    </view>
    <view class="info-row">
      <text class="info-label">手机号</text>
      <input class="info-input" placeholder="请输入手机号" type="number" bindinput="onPhoneInput" value="{{guestPhone}}"/>
    </view>
  </view>

  <!-- 店铺信息 -->
  <view class="card">
    <view class="store-header">
      <text class="store-type-tag {{orderData.type}}">{{orderData.type === 'hotel' ? '酒店民宿' : orderData.type === 'food' ? '美食' : orderData.type === 'travel' ? '周边游玩' : '特产零食'}}</text>
      <text class="store-name-text">{{orderData.storeName}}</text>
    </view>
  </view>

  <!-- 商品信息 -->
  <view class="card">
    <text class="card-title">订单详情</text>
    <!-- 酒店房型 -->
    <view class="order-item" wx:if="{{orderData.type === 'hotel'}}">
      <image class="order-img" src="{{orderData.coverImage}}" mode="aspectFill"/>
      <view class="order-info">
        <text class="order-name">{{orderData.storeName}}</text>
        <text class="order-desc">{{orderData.roomName}}</text>
        <text class="order-sub">{{orderData.checkInDate}} ~ {{orderData.checkOutDate}} · {{orderData.nights}}晚</text>
      </view>
      <text class="price">{{orderData.totalPrice}}</text>
    </view>
    <!-- 美食/游玩 -->
    <view class="order-item" wx:elif="{{orderData.type === 'food' || orderData.type === 'travel'}}">
      <image class="order-img" src="{{orderData.coverImage}}" mode="aspectFill"/>
      <view class="order-info">
        <text class="order-name">{{orderData.storeName}}</text>
        <text class="order-desc" wx:if="{{orderData.type === 'food'}}">到店用餐</text>
        <text class="order-desc" wx:else>景区门票</text>
      </view>
      <text class="price">{{orderData.totalPrice}}</text>
    </view>
    <!-- 商品列表 -->
    <block wx:elif="{{orderData.type === 'product' && orderData.products && orderData.products.length}}">
      <view class="order-item" wx:for="{{orderData.products}}" wx:key="_id">
        <image class="order-img" src="{{item.coverImage}}" mode="aspectFill"/>
        <view class="order-info">
          <text class="order-name">{{item.name}}</text>
          <text class="order-desc">x{{item.quantity}}</text>
        </view>
        <text class="price">{{item.price * item.quantity}}</text>
      </view>
    </block>
    <!-- 单商品 -->
    <view class="order-item" wx:elif="{{orderData.type === 'product'}}">
      <image class="order-img" src="{{orderData.coverImage}}" mode="aspectFill"/>
      <view class="order-info">
        <text class="order-name">{{orderData.productName || orderData.storeName}}</text>
        <text class="order-qty" wx:if="{{orderData.quantity}}">x{{orderData.quantity}}</text>
      </view>
      <text class="price">{{orderData.totalPrice}}</text>
    </view>
  </view>

  <!-- 备注 -->
  <view class="card">
    <text class="card-title">备注</text>
    <textarea class="remark-input" placeholder="有什么要告诉商家的（选填）" bindinput="onRemarkInput" value="{{remark}}"/>
  </view>

  <!-- 底部支付栏 -->
  <view class="bottom-bar">
    <view class="bottom-price">
      <text class="label">应付：</text>
      <text class="price big">{{orderData.totalPrice}}</text>
    </view>
    <view class="btn-primary {{loading ? 'disabled' : ''}}" bindtap="onPay">
      <text wx:if="{{!loading}}">微信支付</text>
      <text wx:else>支付中...</text>
    </view>
  </view>
</view>
