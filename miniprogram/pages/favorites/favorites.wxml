<!--pages/favorites/favorites.wxml-->
<view class="fav-page">
  <view class="page-header">
    <text class="page-title">我的收藏</text>
    <text class="clear-btn" wx:if="{{items.length}}" bindtap="clearAll">清空</text>
  </view>

  <view class="fav-list" wx:if="{{items.length}}">
    <view class="fav-card card" wx:for="{{items}}" wx:key="_id" bindtap="goDetail" data-type="{{item.favType}}" data-id="{{item._id}}">
      <image class="fav-img" src="{{item.coverImage}}" mode="aspectFill"/>
      <view class="fav-info">
        <text class="fav-name ellipsis">{{item.name}}</text>
        <text class="fav-desc ellipsis">{{item.description || ''}}</text>
        <view class="flex-between">
          <text class="price">{{item.minPrice || item.price || 0}}</text>
          <text class="fav-remove" catchtap="removeFavorite" data-id="{{item._id}}">取消收藏</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && !items.length}}">
    <text class="empty-icon">❤️</text>
    <text class="empty-text">还没有收藏</text>
    <text class="empty-hint">浏览商品时点击收藏按钮即可</text>
  </view>
</view>
