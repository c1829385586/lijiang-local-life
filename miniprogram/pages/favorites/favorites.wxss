.fav-page { background: #f5f5f5; min-height: 100vh; }
.page-header { display: flex; justify-content: space-between; align-items: center; padding: 24rpx; background: #fff; }
.page-title { font-size: 34rpx; font-weight: bold; }
.clear-btn { font-size: 26rpx; color: #FF3B30; }
.fav-list { padding: 16rpx 0; }
.fav-card { display: flex; padding: 0 !important; overflow: hidden; }
.fav-img { width: 200rpx; height: 200rpx; flex-shrink: 0; }
.fav-info { flex: 1; padding: 20rpx; display: flex; flex-direction: column; justify-content: space-between; }
.fav-name { font-size: 30rpx; font-weight: bold; }
.fav-desc { font-size: 24rpx; color: #999; }
.fav-remove { font-size: 24rpx; color: #FF6B35; background: #FFF3ED; padding: 8rpx 16rpx; border-radius: 16rpx; }
.empty { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 30rpx; color: #666; margin-top: 16rpx; display: block; }
.empty-hint { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
