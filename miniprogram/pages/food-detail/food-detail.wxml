<!--pages/food-detail/food-detail.wxml-->
<view class="food-detail">
  <swiper class="detail-swiper" indicator-dots>
    <swiper-item wx:for="{{store.images}}" wx:key="*this">
      <image src="{{item}}" mode="aspectFill" class="detail-img" bindtap="previewImage" data-urls="{{store.images}}" data-current="{{index}}"/>
    </swiper-item>
  </swiper>

  <view class="card">
    <view class="flex-between">
      <text class="store-name">{{store.name}}</text>
      <view class="flex">
        <text class="score-text">⭐{{store.score || '4.8'}}</text>
      </view>
    </view>
    <view class="flex" style="margin-top:12rpx">
      <text class="price">{{store.avgPrice || store.minPrice}}</text>
      <text style="font-size:22rpx;color:#999;margin-left:4rpx">/人均</text>
    </view>
    <view class="store-tags">
      <text class="tag" wx:for="{{store.tags}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="store-address flex" bindtap="openMap">
      <text>📍 {{store.address}}</text>
      <text class="address-nav">导航 ></text>
    </view>
    <view class="flex" style="margin-top:12rpx" wx:if="{{store.phone}}">
      <text>📞 {{store.phone}}</text>
      <text class="address-nav" bindtap="callPhone">拨打 ></text>
    </view>
  </view>

  <view class="card" wx:if="{{store.description}}">
    <text class="card-title">商家介绍</text>
    <text class="store-desc">{{store.description}}</text>
  </view>

  <view class="card" wx:if="{{store.recommendDishes && store.recommendDishes.length}}">
    <text class="card-title">推荐菜品</text>
    <view class="dish-list">
      <view class="dish-item" wx:for="{{store.recommendDishes}}" wx:key="name">
        <text class="dish-name">{{item.name}}</text>
        <text class="price">{{item.price}}</text>
      </view>
    </view>
  </view>

  <!-- 评价区域 -->
  <view class="card">
    <view class="flex-between">
      <view class="flex">
        <text class="card-title" style="margin-bottom:0">食客评价</text>
        <text class="review-count" wx:if="{{reviewCount}}">({{reviewCount}})</text>
      </view>
      <view class="flex" wx:if="{{reviewCount}}">
        <text class="review-avg">{{avgRating}}⭐</text>
      </view>
    </view>
    <view class="review-list" wx:if="{{reviews.length}}">
      <view class="review-item" wx:for="{{reviews}}" wx:key="_id">
        <view class="flex">
          <image class="review-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
          <view class="review-meta">
            <text class="review-name">{{item.nickName || '匿名用户'}}</text>
            <text class="review-stars">{{item.rating}}⭐</text>
          </view>
        </view>
        <text class="review-content">{{item.content}}</text>
      </view>
    </view>
    <view class="empty-mini" wx:if="{{!reviews.length}}">
      <text class="empty-mini-text">暂无评价</text>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="bottom-actions">
      <view class="bottom-action-item" bindtap="callPhone">
        <text class="action-icon">📞</text>
        <text class="action-text">电话</text>
      </view>
      <view class="bottom-action-item" bindtap="openMap">
        <text class="action-icon">📍</text>
        <text class="action-text">导航</text>
      </view>
    </view>
    <view class="btn-primary" bindtap="onBookNow" style="flex:1">立即预订</view>
  </view>
</view>
