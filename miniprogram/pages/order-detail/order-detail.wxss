.order-detail { background: #f5f5f5; min-height: 100vh; padding-bottom: 140rpx; }

/* 状态栏 */
.status-bar { padding: 40rpx 30rpx; }
.status-bar.pending { background: linear-gradient(135deg, #FF9500, #FFB84D); }
.status-bar.paid { background: linear-gradient(135deg, #4CD964, #7BE08A); }
.status-bar.completed { background: linear-gradient(135deg, #8E8E93, #AEAEB2); }
.status-bar.cancelled, .status-bar.rejected { background: linear-gradient(135deg, #ccc, #ddd); }
.status-text { color: #fff; font-size: 36rpx; font-weight: bold; display: block; }
.status-hint { color: rgba(255,255,255,0.8); font-size: 24rpx; margin-top: 8rpx; display: block; }

/* 卡片 */
.card { background: #fff; border-radius: 16rpx; margin: 16rpx 20rpx; padding: 24rpx; }
.card-title { font-size: 28rpx; font-weight: bold; display: block; margin-bottom: 16rpx; }
.store-link { display: flex; justify-content: space-between; align-items: center; padding-bottom: 16rpx; border-bottom: 1rpx solid #f5f5f5; margin-bottom: 16rpx; }
.store-name { font-size: 30rpx; font-weight: bold; }
.menu-arrow { color: #ccc; font-size: 32rpx; }
.order-item { display: flex; align-items: center; }
.order-img { width: 140rpx; height: 140rpx; border-radius: 12rpx; flex-shrink: 0; }
.order-info { flex: 1; margin-left: 16rpx; }
.order-name { font-size: 28rpx; font-weight: bold; display: block; }
.order-qty { font-size: 24rpx; color: #999; }
.price { color: #FF6B35; font-weight: bold; font-size: 32rpx; }
.price::before { content: '¥'; font-size: 24rpx; }

.info-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #f5f5f5; font-size: 26rpx; }
.info-row:last-child { border-bottom: none; }
.info-label { color: #999; }
.addr-info { font-size: 26rpx; display: block; }
.addr-detail { font-size: 24rpx; color: #666; display: block; margin-top: 8rpx; }
.remark-text { font-size: 26rpx; color: #666; line-height: 1.6; }

/* 操作栏 */
.action-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex; justify-content: flex-end; gap: 16rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.action-btn {
  padding: 14rpx 32rpx; border: 1rpx solid #ddd;
  border-radius: 32rpx; font-size: 26rpx; color: #666;
}
.action-btn.primary { background: #FF6B35; color: #fff; border-color: #FF6B35; }
