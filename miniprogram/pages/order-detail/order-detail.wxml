<!--pages/order-detail/order-detail.wxml-->
<view class="order-detail">
  <!-- 订单状态 -->
  <view class="status-bar {{order.status}}">
    <text class="status-text">{{statusMap[order.status]}}</text>
    <text class="status-hint" wx:if="{{order.status === 'pending'}}">请尽快完成支付</text>
    <text class="status-hint" wx:elif="{{order.status === 'paid'}}">商户将尽快为您处理</text>
    <text class="status-hint" wx:elif="{{order.status === 'completed'}}">感谢您的支持</text>
  </view>

  <!-- 商品信息 -->
  <view class="card">
    <view class="store-link" bindtap="goStore">
      <text class="store-name">{{order.storeName}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="order-item">
      <image class="order-img" src="{{order.coverImage}}" mode="aspectFill"/>
      <view class="order-info">
        <text class="order-name">{{order.roomName || order.storeName}}</text>
        <text class="order-qty" wx:if="{{order.quantity}}">x{{order.quantity}}</text>
      </view>
      <text class="price">{{order.totalPrice}}</text>
    </view>
  </view>

  <!-- 酒店入住信息 -->
  <view class="card" wx:if="{{order.type === 'hotel'}}">
    <text class="card-title">入住信息</text>
    <view class="info-row"><text class="info-label">入住日期</text><text>{{order.checkInDate}}</text></view>
    <view class="info-row"><text class="info-label">退房日期</text><text>{{order.checkOutDate}}</text></view>
    <view class="info-row"><text class="info-label">入住天数</text><text>{{order.nights}}晚</text></view>
    <view class="info-row"><text class="info-label">入住人</text><text>{{order.guestName}}</text></view>
    <view class="info-row"><text class="info-label">手机号</text><text>{{order.guestPhone}}</text></view>
  </view>

  <!-- 收货地址 -->
  <view class="card" wx:if="{{order.address}}">
    <text class="card-title">收货地址</text>
    <text class="addr-info">{{order.address.name}} {{order.address.phone}}</text>
    <text class="addr-detail">{{order.address.province}}{{order.address.city}}{{order.address.detail}}</text>
  </view>

  <!-- 备注 -->
  <view class="card" wx:if="{{order.remark}}">
    <text class="card-title">备注</text>
    <text class="remark-text">{{order.remark}}</text>
  </view>

  <!-- 订单信息 -->
  <view class="card">
    <text class="card-title">订单信息</text>
    <view class="info-row"><text class="info-label">订单号</text><text>{{order.orderNo}}</text></view>
    <view class="info-row"><text class="info-label">下单时间</text><text>{{order.createdAt}}</text></view>
    <view class="info-row" wx:if="{{order.paidAt}}"><text class="info-label">支付时间</text><text>{{order.paidAt}}</text></view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <view class="action-btn" wx:if="{{order.status === 'pending'}}" bindtap="cancelOrder">取消订单</view>
    <view class="action-btn primary" wx:if="{{order.status === 'pending'}}" bindtap="goPay">去支付</view>
    <view class="action-btn" wx:if="{{order.status === 'paid'}}" bindtap="confirmOrder">确认入住/收货</view>
    <view class="action-btn primary" wx:if="{{canReview}}" bindtap="goReview">评价</view>
  </view>
</view>
