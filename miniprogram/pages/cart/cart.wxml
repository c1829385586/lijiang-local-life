<!--pages/cart/cart.wxml-->
<view class="cart-page">
  <view class="cart-header" wx:if="{{cartItems.length}}">
    <text class="cart-count">购物车({{cartItems.length}})</text>
    <text class="cart-clear" bindtap="clearAll">清空</text>
  </view>

  <view class="cart-list" wx:if="{{cartItems.length}}">
    <view class="cart-item card" wx:for="{{cartItems}}" wx:key="_id">
      <view class="flex">
        <view class="checkbox-wrap" bindtap="toggleItem" data-index="{{index}}">
          <view class="custom-checkbox {{item.checked ? 'checked' : ''}}">
            <text wx:if="{{item.checked}}">✓</text>
          </view>
        </view>
        <image class="cart-img" src="{{item.coverImage}}" mode="aspectFill"/>
        <view class="cart-info">
          <text class="cart-name">{{item.name}}</text>
          <text class="cart-desc" wx:if="{{item.canDeliverToRoom}}">🏨可送到房间</text>
          <view class="flex-between">
            <text class="price">{{item.price}}</text>
            <view class="qty-control">
              <text class="qty-btn" catchtap="decrease" data-index="{{index}}">-</text>
              <text class="qty-num">{{item.quantity}}</text>
              <text class="qty-btn" catchtap="increase" data-index="{{index}}">+</text>
            </view>
          </view>
        </view>
      </view>
      <text class="cart-delete" catchtap="removeItem" data-index="{{index}}">删除</text>
    </view>
  </view>

  <view class="empty" wx:if="{{!cartItems.length}}">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车空空如也</text>
    <text class="empty-hint">去逛逛吧</text>
    <view class="btn-primary empty-btn" bindtap="goShopping">去逛逛</view>
  </view>

  <view class="cart-bottom" wx:if="{{cartItems.length}}">
    <view class="flex" bindtap="toggleAll">
      <view class="custom-checkbox {{allChecked ? 'checked' : ''}}">
        <text wx:if="{{allChecked}}">✓</text>
      </view>
      <text style="margin-left:12rpx">全选</text>
    </view>
    <view class="flex">
      <text class="total-label">合计: </text>
      <text class="price total-price">{{totalPrice}}</text>
      <view class="btn-primary cart-buy" bindtap="onCheckout">去结算({{checkedCount}})</view>
    </view>
  </view>
</view>
