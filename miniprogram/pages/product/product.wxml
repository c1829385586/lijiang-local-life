<!--pages/product/product.wxml-->
<view class="product-page">
  <view class="header-bar">
    <view class="search-wrap">
      <input class="search-input" placeholder="搜索特产零食" bindinput="onSearchInput" bindconfirm="onSearch" value="{{keyword}}"/>
    </view>
    <view class="filter-bar">
      <view class="filter-item {{category === '' ? 'active' : ''}}" bindtap="setCategory" data-cat="">全部</view>
      <view class="filter-item {{category === '特产干货' ? 'active' : ''}}" bindtap="setCategory" data-cat="特产干货">特产干货</view>
      <view class="filter-item {{category === '手工美食' ? 'active' : ''}}" bindtap="setCategory" data-cat="手工美食">手工美食</view>
      <view class="filter-item {{category === '小零食' ? 'active' : ''}}" bindtap="setCategory" data-cat="小零食">小零食</view>
      <view class="filter-item {{category === '伴手礼' ? 'active' : ''}}" bindtap="setCategory" data-cat="伴手礼">伴手礼</view>
    </view>
  </view>
  <view class="product-grid">
    <view class="product-card" wx:for="{{products}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
      <image class="product-img" src="{{item.coverImage}}" mode="aspectFill"/>
      <view class="product-info">
        <text class="product-name ellipsis">{{item.name}}</text>
        <view class="flex-between">
          <text class="price">{{item.price}}</text>
          <text class="product-original" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
        </view>
        <view class="flex-between">
          <text class="product-sales">已售{{item.sales || 0}}</text>
          <text class="product-deliver" wx:if="{{item.canDeliverToRoom}}">🏨送到房间</text>
        </view>
      </view>
    </view>
  </view>
  <view class="empty" wx:if="{{!loading && !products.length}}">
    <text class="empty-icon">🎁</text><text class="empty-text">暂无商品</text>
  </view>
</view>
