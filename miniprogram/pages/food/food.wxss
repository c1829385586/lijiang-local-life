.food-card { display: flex; padding: 0 !important; overflow: hidden; }
.food-img { width: 220rpx; height: 200rpx; flex-shrink: 0; border-radius: 0; }
.food-info { flex: 1; padding: 16rpx 20rpx; display: flex; flex-direction: column; justify-content: space-between; }
.food-name { font-size: 30rpx; font-weight: bold; }
.food-desc { font-size: 24rpx; color: #999; margin: 4rpx 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.food-price-label { font-size: 20rpx; color: #999; margin-left: 4rpx; }
.food-distance { font-size: 22rpx; color: #999; }
.food-score { font-size: 22rpx; color: #FF9500; margin-right: 8rpx; }
