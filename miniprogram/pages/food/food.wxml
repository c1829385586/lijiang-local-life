<!--pages/food/food.wxml-->
<view class="food-page">
  <view class="header-bar">
    <view class="search-wrap">
      <input class="search-input" placeholder="搜索美食" bindinput="onSearchInput" bindconfirm="onSearch" value="{{keyword}}"/>
    </view>
    <view class="filter-bar">
      <view class="filter-item {{sortBy === 'score' ? 'active' : ''}}" bindtap="setSort" data-sort="score">好评优先</view>
      <view class="filter-item {{sortBy === 'distance' ? 'active' : ''}}" bindtap="setSort" data-sort="distance">距离最近</view>
      <view class="filter-item {{sortBy === 'price' ? 'active' : ''}}" bindtap="setSort" data-sort="price">人均</view>
    </view>
  </view>
  <view class="food-list">
    <view class="food-card card" wx:for="{{foods}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
      <image class="food-img" src="{{item.coverImage}}" mode="aspectFill"/>
      <view class="food-info">
        <text class="food-name">{{item.name}}</text>
        <text class="food-desc ellipsis2">{{item.description}}</text>
        <view class="flex-between">
          <view class="flex">
            <text class="price">{{item.avgPrice || item.minPrice}}</text>
            <text class="food-price-label">/人均</text>
          </view>
          <text class="food-distance">{{item.distance || ''}}</text>
        </view>
        <view class="flex">
          <text class="food-score">⭐{{item.score || '4.8'}}</text>
          <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
        </view>
      </view>
    </view>
  </view>
  <view class="empty" wx:if="{{!loading && !foods.length}}">
    <text class="empty-icon">🍜</text><text class="empty-text">暂无美食</text>
  </view>
</view>
