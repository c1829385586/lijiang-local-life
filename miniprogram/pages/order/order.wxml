<!--pages/order/order.wxml-->
<view class="order-page">
  <!-- 订阅通知引导 -->
  <view class="subscribe-banner" wx:if="{{showSubscribe}}" bindtap="subscribeNotifications">
    <text class="subscribe-icon">🔔</text>
    <view class="subscribe-text">
      <text class="subscribe-title">开启订单通知</text>
      <text class="subscribe-desc">订单状态变更时第一时间通知您</text>
    </view>
    <view class="subscribe-btn">立即开启</view>
    <text class="subscribe-close" catchtap="closeSubscribe">✕</text>
  </view>

  <!-- 顶部Tab -->
  <scroll-view scroll-x class="order-tabs">
    <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
    <view class="tab-item {{currentTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">待支付</view>
    <view class="tab-item {{currentTab === 'paid' ? 'active' : ''}}" bindtap="switchTab" data-tab="paid">已支付</view>
    <view class="tab-item {{currentTab === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-tab="completed">已完成</view>
    <view class="tab-item {{currentTab === 'cancelled' ? 'active' : ''}}" bindtap="switchTab" data-tab="cancelled">已取消</view>
  </scroll-view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{orders.length}}">
    <view class="order-card card" wx:for="{{orders}}" wx:key="_id">
      <view class="flex-between order-header">
        <text class="order-store">{{item.storeName}}</text>
        <text class="order-status {{item.status}}">{{statusMap[item.status]}}</text>
      </view>
      <view class="order-body" bindtap="goDetail" data-id="{{item._id}}">
        <image class="order-img" src="{{item.coverImage}}" mode="aspectFill"/>
        <view class="order-info">
          <text class="order-name">{{item.roomName || item.storeName}}</text>
          <text class="order-no">订单号：{{item.orderNo}}</text>
          <text class="order-time">{{item.createdAt}}</text>
        </view>
        <text class="price">{{item.totalPrice}}</text>
      </view>
      <view class="order-actions">
        <view class="action-btn" wx:if="{{item.status === 'pending'}}" catchtap="cancelOrder" data-id="{{item._id}}">取消订单</view>
        <view class="action-btn primary" wx:if="{{item.status === 'pending'}}" catchtap="goPay" data-id="{{item._id}}">去支付</view>
        <view class="action-btn" wx:if="{{item.status === 'paid'}}" catchtap="confirmOrder" data-id="{{item._id}}">确认入住</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && !orders.length}}">
    <text class="empty-icon">📦</text>
    <text class="empty-text">暂无订单</text>
  </view>
</view>
