<!--pages/browse-history/browse-history.wxml-->
<view class="history-page">
  <view class="page-header">
    <text class="page-title">浏览历史</text>
    <text class="clear-btn" wx:if="{{items.length}}" bindtap="clearAll">清空</text>
  </view>
  <view class="history-list" wx:if="{{items.length}}">
    <view class="history-card card" wx:for="{{items}}" wx:key="time" bindtap="goDetail" data-type="{{item.type}}" data-id="{{item.id}}">
      <image class="history-img" src="{{item.coverImage}}" mode="aspectFill"/>
      <view class="history-info">
        <text class="history-name ellipsis">{{item.name}}</text>
        <view class="flex-between">
          <text class="history-type tag">{{item.typeName}}</text>
          <text class="history-time">{{item.timeStr}}</text>
        </view>
      </view>
    </view>
  </view>
  <view class="empty" wx:if="{{!items.length}}">
    <text class="empty-icon">🕐</text>
    <text class="empty-text">暂无浏览记录</text>
  </view>
</view>
