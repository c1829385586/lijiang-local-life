.history-page { background: #f5f5f5; min-height: 100vh; }
.page-header { display: flex; justify-content: space-between; align-items: center; padding: 24rpx; background: #fff; }
.page-title { font-size: 34rpx; font-weight: bold; }
.clear-btn { font-size: 26rpx; color: #FF3B30; }
.history-card { display: flex; padding: 0 !important; overflow: hidden; }
.history-img { width: 160rpx; height: 160rpx; flex-shrink: 0; }
.history-info { flex: 1; padding: 20rpx; display: flex; flex-direction: column; justify-content: space-between; }
.history-name { font-size: 28rpx; font-weight: bold; }
.history-time { font-size: 22rpx; color: #ccc; }
.history-type { font-size: 22rpx; }
.empty { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 28rpx; color: #999; margin-top: 16rpx; }
.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.tag { background: #FFF3ED; color: #FF6B35; font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; display: inline-block; }
