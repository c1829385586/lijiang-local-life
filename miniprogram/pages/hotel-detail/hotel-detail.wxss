.hotel-detail { padding-bottom: 120rpx; }
.detail-swiper { height: 400rpx; }
.detail-img { width: 100%; height: 400rpx; }
.store-name { font-size: 36rpx; font-weight: bold; }
.score-text { font-size: 26rpx; color: #FF9500; }
.store-tags { margin: 12rpx 0; }
.store-address { margin-top: 12rpx; font-size: 26rpx; color: #666; justify-content: space-between; }
.address-nav { color: #FF6B35; font-size: 24rpx; }
.card-title { font-size: 30rpx; font-weight: bold; display: block; margin-bottom: 16rpx; }
.service-grid { display: flex; flex-wrap: wrap; }
.service-item { width: 25%; display: flex; flex-direction: column; align-items: center; padding: 16rpx 0; }
.service-icon { font-size: 40rpx; }
.service-name { font-size: 22rpx; color: #666; margin-top: 8rpx; }
.room-list { margin-top: 8rpx; }
.room-item { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.room-item:last-child { border-bottom: none; }
.room-img { width: 180rpx; height: 130rpx; border-radius: 12rpx; flex-shrink: 0; }
.room-info { flex: 1; margin-left: 16rpx; display: flex; flex-direction: column; justify-content: space-between; }
.room-name { font-size: 28rpx; font-weight: bold; }
.room-desc { font-size: 22rpx; color: #999; }
.room-stock { font-size: 22rpx; color: #4CD964; }
.room-stock.sold-out { color: #999; }
.scroll-h { white-space: nowrap; padding: 12rpx 0; }
.nearby-item { display: inline-block; width: 200rpx; margin-right: 16rpx; }
.nearby-img { width: 200rpx; height: 200rpx; border-radius: 12rpx; }
.nearby-name { font-size: 24rpx; display: block; margin-top: 8rpx; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); display: flex; justify-content: space-between; align-items: center; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06); }
.bottom-price { display: flex; flex-direction: column; }
.price.big { font-size: 40rpx; }
.label { font-size: 22rpx; color: #999; }
